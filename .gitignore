# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ─── Build output ───────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# Generated service worker / Workbox output (rebuilt from src/sw.ts on every
# build — see vite.config.ts's injectManifest setup)
public/sw.js
public/workbox-*.js
public/registerSW.js

# ─── Bun ────────────────────────────────────────────────────────────────────
# bun.lockb is intentionally NOT ignored — it's committed for reproducible
# installs across contributors and CI.
.bun/

# ─── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# ─── Editor / IDE ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS files ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Environment variables ──────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Testing / coverage ─────────────────────────────────────────────────────
coverage/

# ─── TypeScript build info ──────────────────────────────────────────────────
*.tsbuildinfo

# ─── Vite ───────────────────────────────────────────────────────────────────
.vite/

# ─── PWA install assets you don't want auto-committed (uncomment if relevant)
# Most projects DO want their actual icons committed — only ignore generated
# ones if you have a script that regenerates them from a source SVG/logo.
# public/icons/generated/